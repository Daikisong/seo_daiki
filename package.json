{
  "name": "global-import-lab",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "dev": "pnpm --filter @global-import-lab/web dev",
    "build": "pnpm db:generate && pnpm --filter @global-import-lab/web build",
    "typecheck": "pnpm db:generate && pnpm -r typecheck",
    "seo:validate": "pnpm --filter @global-import-lab/validators validate",
    "db:generate": "prisma generate --config prisma.config.ts",
    "db:migrate": "prisma migrate dev --config prisma.config.ts",
    "db:seed": "pnpm --filter @global-import-lab/db seed",
    "db:admin": "pnpm --filter @global-import-lab/db admin",
    "worker": "python3 workers/python/cli.py",
    "worker:pipeline": "python3 workers/python/cli.py run-pipeline",
    "trend:init-markets": "python3 workers/python/cli.py trend:init-markets",
    "trend:import": "python3 workers/python/cli.py trend:import-signals --file data/seeds/trend-signals.csv",
    "trend:cluster": "python3 workers/python/cli.py trend:cluster",
    "trend:score": "python3 workers/python/cli.py trend:score",
    "trend:report": "python3 workers/python/cli.py trend:report",
    "trend:generate-keywords": "python3 workers/python/cli.py trend:generate-keywords",
    "serp:import": "python3 workers/python/cli.py serp:import-results --file data/seeds/serp-results.csv",
    "serp:analyze": "python3 workers/python/cli.py serp:analyze-pages",
    "serp:report": "python3 workers/python/cli.py serp:report",
    "strategy:create": "python3 workers/python/cli.py strategy:create",
    "strategy:generate-brief": "python3 workers/python/cli.py strategy:generate-brief",
    "post:generate-test": "python3 workers/python/cli.py post:generate-test",
    "post:publish-test": "python3 workers/python/cli.py post:publish-test --mode noindex",
    "calendar:build": "python3 workers/python/cli.py calendar:build-all",
    "calendar:report": "python3 workers/python/cli.py calendar:explain",
    "performance:import": "python3 workers/python/cli.py performance:import-search-console",
    "performance:recommend": "python3 workers/python/cli.py performance:recommend-actions",
    "products:import-candidates": "python3 workers/python/cli.py products:import-candidates --file data/seeds/product-candidates.csv",
    "products:analyze-candidates": "python3 workers/python/cli.py products:analyze-candidates",
    "monetization:create-review": "python3 workers/python/cli.py monetization:create-review",
    "monetization:draft-placements": "python3 workers/python/cli.py monetization:draft-placements",
    "monetization:apply-approved": "python3 workers/python/cli.py monetization:apply-approved",
    "pipeline:trend-to-post": "python3 workers/python/cli.py pipeline:trend-to-post",
    "pipeline:post-to-product-analysis": "python3 workers/python/cli.py pipeline:post-to-product-analysis",
    "pipeline:monetization-review": "python3 workers/python/cli.py pipeline:monetization-review",
    "brief:generate": "python3 workers/python/cli.py strategy:generate-brief",
    "offers:match": "python3 workers/python/cli.py match-affiliate-offers --offers-file data/seeds/offers.csv",
    "publishing:gate": "python3 workers/python/cli.py run-publishing-gate",
    "localization:score": "python3 workers/python/cli.py score-localization",
    "affiliate:audit": "python3 workers/python/cli.py match-affiliate-offers --offers-file data/seeds/offers.csv",
    "compliance:audit": "python3 workers/python/cli.py run-publishing-gate",
    "distribution:generate": "python3 workers/python/cli.py generate-distribution-assets",
    "links:assets:score": "python3 workers/python/cli.py score-linkable-assets",
    "links:prospects:score": "python3 workers/python/cli.py score-link-prospects"
  },
  "devDependencies": {
    "@prisma/client": "7.8.0",
    "dotenv": "17.4.2",
    "prisma": "7.8.0",
    "tsx": "4.21.0",
    "typescript": "6.0.3"
  }
}
