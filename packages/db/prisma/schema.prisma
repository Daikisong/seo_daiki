generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id                 String          @id @default(cuid())
  canonicalName      String
  slug               String          @unique
  category           String
  brandClaim         String?
  identityConfidence Float           @default(0)
  imageHash          String?
  archivedAt         DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  variants       Variant[]
  sellerClaims   SellerClaim[]
  verifiedClaims VerifiedClaim[]
  reviewSignals  ReviewSignal[]
  priceSnapshots PriceSnapshot[]
  marketRisks    MarketRisk[]
  labEvidenceAssets LabEvidenceAsset[]
  evidencePacks  EvidencePack[]
  articles       Article[]
  offers         Offer[]

  @@index([category])
}

model Variant {
  id            String   @id @default(cuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  sourceSku     String?
  optionName    String
  wattageClaim  Int?
  plugType      String?
  cableIncluded Boolean?
  sourceUrl     String
  affiliateUrl  String?
  sellerName    String?
  sellerId      String?
  riskFlags     Json?
  archivedAt    DateTime?
  createdAt     DateTime @default(now())

  priceSnapshots PriceSnapshot[]
}

model SellerClaim {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  claimType  String
  claimValue String
  rawText    String?
  sourceUrl  String?
  capturedAt DateTime @default(now())
  confidence Float    @default(0.5)
  archivedAt DateTime?

  @@index([productId, claimType])
}

model VerifiedClaim {
  id          String    @id @default(cuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  testType    String
  resultValue String
  unit        String?
  method      String
  evidenceUrl String?
  confidence  Float     @default(0.8)
  testedAt    DateTime?
  archivedAt  DateTime?

  labEvidenceAssets LabEvidenceAsset[]

  @@index([productId, testType])
}

model LabEvidenceAsset {
  id              String         @id @default(cuid())
  productId       String?
  product         Product?       @relation(fields: [productId], references: [id], onDelete: SetNull)
  verifiedClaimId String?
  verifiedClaim   VerifiedClaim? @relation(fields: [verifiedClaimId], references: [id], onDelete: SetNull)
  measurementType String
  fileName        String
  storageKey      String         @unique
  publicUrl       String
  mimeType        String
  sizeBytes       Int
  checksumSha256  String
  notes           String?
  uploadedAt      DateTime       @default(now())

  @@index([productId, measurementType])
  @@index([verifiedClaimId])
}

model ReviewSignal {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  locale     String
  topic      String
  sentiment  String
  count      Int
  confidence Float
  window     String?
  capturedAt DateTime @default(now())

  @@index([productId, locale])
}

model PriceSnapshot {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId  String?
  variant    Variant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  country    String?
  currency   String
  price      Decimal  @db.Decimal(10, 2)
  shipping   Decimal? @db.Decimal(10, 2)
  coupon     Decimal? @db.Decimal(10, 2)
  finalPrice Decimal? @db.Decimal(10, 2)
  capturedAt DateTime @default(now())

  @@index([productId, country, capturedAt])
}

model MarketRisk {
  id                   String  @id @default(cuid())
  productId            String
  product              Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  locale               String
  country              String?
  plugRisk             String?
  customsRisk          String?
  certificationRisk    String?
  returnRisk           String?
  localAlternativeNote String?
  score                Float   @default(0.5)
  archivedAt           DateTime?

  @@index([productId, locale])
}

model EvidencePack {
  id        String   @id @default(cuid())
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  locale    String
  packJson  Json
  archivedAt DateTime?
  createdAt DateTime @default(now())

  @@index([productId, locale])
}

model Article {
  id              String   @id @default(cuid())
  productId       String?
  product         Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  locale          String
  slug            String
  type            String
  title           String
  h1              String?
  metaDescription String?
  summary         String?
  contentMdx      String
  sections        Json?
  internalLinks   Json?
  affiliateLinks  Json?
  evidenceIds     Json?
  jsonLd          Json?
  qualityScore    Int      @default(0)
  indexStatus     String   @default("pending")
  publishStatus   String   @default("draft")
  healthSensitivity String @default("none")
  complianceStatus String @default("unchecked")
  complianceJson   Json?
  canonicalUrl    String?
  hreflangMap     Json?
  archivedAt      DateTime?
  lastUpdated     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  affiliateClicks AffiliateClick[]
  affiliatePlacements AffiliatePlacement[]
  sourceTranslationGroups TranslationGroup[] @relation("TranslationGroupSourceArticle")
  translationVariants TranslationVariant[]
  publishingJobs PublishingJob[]

  @@unique([locale, slug, type])
  @@index([locale, type, indexStatus])
  @@index([healthSensitivity, complianceStatus])
}

model Merchant {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  domain          String
  merchantType    String
  allowedDomains  Json
  defaultRel      String   @default("sponsored nofollow")
  healthSensitive Boolean  @default(false)
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  programs        AffiliateProgram[]
  offers          Offer[]
  affiliateClicks AffiliateClick[]
}

model AffiliateProgram {
  id         String   @id @default(cuid())
  merchantId String
  merchant   Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  network    String
  trackingId String?
  termsNote  String?
  status     String   @default("active")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  offers     Offer[]
}

model Offer {
  id              String   @id @default(cuid())
  merchantId      String
  merchant        Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  programId       String?
  program         AffiliateProgram? @relation(fields: [programId], references: [id], onDelete: SetNull)
  productId       String?
  product         Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  topicId         String?
  topic           Topic? @relation(fields: [topicId], references: [id], onDelete: SetNull)
  title           String
  description     String?
  url             String
  affiliateUrl    String
  price           Decimal? @db.Decimal(10, 2)
  currency        String?
  locale          String?
  country         String?
  category        String
  evidenceLevel   String   @default("merchant_claim")
  healthSensitive Boolean  @default(false)
  lastCheckedAt   DateTime?
  status          String   @default("active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  affiliatePlacements AffiliatePlacement[]
  affiliateClicks     AffiliateClick[]

  @@index([merchantId, locale, category])
  @@index([productId])
  @@index([topicId])
}

model TrendSource {
  id         String   @id @default(cuid())
  name       String
  slug       String   @unique
  sourceType String
  locale     String?
  country    String?
  enabled    Boolean  @default(true)
  configJson Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  signals    TrendSignal[]
}

model TrendSignal {
  id                String   @id @default(cuid())
  sourceId          String
  source            TrendSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  locale            String
  country           String?
  query             String
  topicRaw          String
  url               String?
  volumeScore       Float    @default(0)
  growthScore       Float    @default(0)
  competitionScore  Float    @default(0)
  commercialScore   Float    @default(0)
  freshnessScore    Float    @default(0)
  evidenceFitScore  Float    @default(0)
  affiliateFitScore Float    @default(0)
  capturedAt        DateTime @default(now())

  topicSignals      TopicSignal[]

  @@index([locale, country, capturedAt])
  @@index([query])
}

model Topic {
  id              String   @id @default(cuid())
  canonicalTopic  String
  slug            String   @unique
  cluster         String
  primaryLocale   String
  intent          String
  healthSensitive Boolean  @default(false)
  status          String   @default("candidate")
  score           Float    @default(0)
  scoreBreakdown  Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  topicSignals    TopicSignal[]
  contentBriefs   ContentBrief[]
  offers          Offer[]
  translationGroups TranslationGroup[]
  publishingJobs PublishingJob[]
}

model TopicSignal {
  id            String @id @default(cuid())
  topicId       String
  topic         Topic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  trendSignalId String
  trendSignal   TrendSignal @relation(fields: [trendSignalId], references: [id], onDelete: Cascade)
  weight        Float @default(1)

  @@index([topicId])
  @@index([trendSignalId])
  @@unique([topicId, trendSignalId])
}

model ContentBrief {
  id                String   @id @default(cuid())
  topicId           String
  topic             Topic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  locale            String
  articleType       String
  titleCandidate    String
  h1Candidate       String?
  searchIntent      String
  outlineJson       Json
  requiredEvidence  Json?
  merchantFitJson   Json?
  localizationNotes Json?
  healthSensitivity String   @default("none")
  status            String   @default("draft")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([topicId, locale])
}

model TranslationGroup {
  id               String   @id @default(cuid())
  canonicalTopicId String?
  canonicalTopic   Topic?   @relation(fields: [canonicalTopicId], references: [id], onDelete: SetNull)
  sourceArticleId  String?
  sourceArticle    Article? @relation("TranslationGroupSourceArticle", fields: [sourceArticleId], references: [id], onDelete: SetNull)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  variants         TranslationVariant[]

  @@index([canonicalTopicId])
  @@index([sourceArticleId])
}

model TranslationVariant {
  id                     String   @id @default(cuid())
  groupId                String
  group                  TranslationGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  articleId              String
  article                Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  locale                 String
  sourceLocale           String?
  localizationDepthScore Float    @default(0)
  status                 String   @default("draft")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([groupId, locale])
  @@index([articleId])
  @@unique([groupId, locale])
  @@unique([articleId])
}

model PublishingJob {
  id         String   @id @default(cuid())
  topicId    String?
  topic      Topic?   @relation(fields: [topicId], references: [id], onDelete: SetNull)
  articleId  String?
  article    Article? @relation(fields: [articleId], references: [id], onDelete: SetNull)
  locale     String
  jobType    String
  status     String   @default("queued")
  inputJson  Json?
  outputJson Json?
  error      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([status, jobType])
  @@index([articleId])
  @@index([topicId])
}

model AffiliatePlacement {
  id              String   @id @default(cuid())
  articleId       String
  article         Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  offerId         String
  offer           Offer    @relation(fields: [offerId], references: [id], onDelete: Cascade)
  placementType   String
  anchorText      String
  rel             String   @default("sponsored nofollow")
  disclosureShown Boolean  @default(false)
  status          String   @default("draft")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  affiliateClicks AffiliateClick[]

  @@index([articleId, status])
  @@index([offerId])
}

model AffiliateClick {
  id          String   @id @default(cuid())
  articleId   String?
  article     Article? @relation(fields: [articleId], references: [id], onDelete: SetNull)
  placementId String?
  placement   AffiliatePlacement? @relation(fields: [placementId], references: [id], onDelete: SetNull)
  offerId     String?
  offer       Offer? @relation(fields: [offerId], references: [id], onDelete: SetNull)
  merchantId  String?
  merchant    Merchant? @relation(fields: [merchantId], references: [id], onDelete: SetNull)
  productId   String?
  variantId   String?
  locale      String?
  targetUrl   String
  clickedAt   DateTime @default(now())
  referrer    String?
  utm         Json?

  @@index([productId, locale])
  @@index([placementId])
  @@index([offerId])
  @@index([merchantId])
}

model SearchConsoleMetric {
  id          String   @id @default(cuid())
  page        String
  query       String
  country     String?
  device      String?
  clicks      Int      @default(0)
  impressions Int      @default(0)
  ctr         Float    @default(0)
  position    Float    @default(0)
  startDate   DateTime?
  endDate     DateTime?
  importedAt  DateTime @default(now())

  @@index([page, query])
  @@index([country, device])
}

model PageRefreshSuggestion {
  id        String   @id @default(cuid())
  page      String
  query     String?
  reason    String
  actions   Json
  status    String   @default("open")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([page, status])
}

model AuditLog {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  action     String
  actor      String?
  summary    String?
  beforeJson Json?
  afterJson  Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}
