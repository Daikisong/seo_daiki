generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id                 String          @id @default(cuid())
  canonicalName      String
  slug               String          @unique
  category           String
  brandClaim         String?
  identityConfidence Float           @default(0)
  imageHash          String?
  archivedAt         DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  variants       Variant[]
  sellerClaims   SellerClaim[]
  verifiedClaims VerifiedClaim[]
  reviewSignals  ReviewSignal[]
  priceSnapshots PriceSnapshot[]
  marketRisks    MarketRisk[]
  labEvidenceAssets LabEvidenceAsset[]
  evidencePacks  EvidencePack[]
  articles       Article[]
  offers         Offer[]

  @@index([category])
}

model Variant {
  id            String   @id @default(cuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  sourceSku     String?
  optionName    String
  wattageClaim  Int?
  plugType      String?
  cableIncluded Boolean?
  sourceUrl     String
  affiliateUrl  String?
  sellerName    String?
  sellerId      String?
  riskFlags     Json?
  archivedAt    DateTime?
  createdAt     DateTime @default(now())

  priceSnapshots PriceSnapshot[]
}

model SellerClaim {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  claimType  String
  claimValue String
  rawText    String?
  sourceUrl  String?
  capturedAt DateTime @default(now())
  confidence Float    @default(0.5)
  archivedAt DateTime?

  @@index([productId, claimType])
}

model VerifiedClaim {
  id          String    @id @default(cuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  testType    String
  resultValue String
  unit        String?
  method      String
  evidenceUrl String?
  confidence  Float     @default(0.8)
  testedAt    DateTime?
  archivedAt  DateTime?

  labEvidenceAssets LabEvidenceAsset[]

  @@index([productId, testType])
}

model LabEvidenceAsset {
  id              String         @id @default(cuid())
  productId       String?
  product         Product?       @relation(fields: [productId], references: [id], onDelete: SetNull)
  verifiedClaimId String?
  verifiedClaim   VerifiedClaim? @relation(fields: [verifiedClaimId], references: [id], onDelete: SetNull)
  measurementType String
  fileName        String
  storageKey      String         @unique
  publicUrl       String
  mimeType        String
  sizeBytes       Int
  checksumSha256  String
  notes           String?
  uploadedAt      DateTime       @default(now())

  @@index([productId, measurementType])
  @@index([verifiedClaimId])
}

model ReviewSignal {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  locale     String
  topic      String
  sentiment  String
  count      Int
  confidence Float
  window     String?
  capturedAt DateTime @default(now())

  @@index([productId, locale])
}

model PriceSnapshot {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId  String?
  variant    Variant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  country    String?
  currency   String
  price      Decimal  @db.Decimal(10, 2)
  shipping   Decimal? @db.Decimal(10, 2)
  coupon     Decimal? @db.Decimal(10, 2)
  finalPrice Decimal? @db.Decimal(10, 2)
  capturedAt DateTime @default(now())

  @@index([productId, country, capturedAt])
}

model MarketRisk {
  id                   String  @id @default(cuid())
  productId            String
  product              Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  locale               String
  country              String?
  plugRisk             String?
  customsRisk          String?
  certificationRisk    String?
  returnRisk           String?
  localAlternativeNote String?
  score                Float   @default(0.5)
  archivedAt           DateTime?

  @@index([productId, locale])
}

model EvidencePack {
  id        String   @id @default(cuid())
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  locale    String
  packJson  Json
  archivedAt DateTime?
  createdAt DateTime @default(now())

  @@index([productId, locale])
}

model Article {
  id              String   @id @default(cuid())
  productId       String?
  product         Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  market          String?
  language        String?
  locale          String
  slug            String
  type            String
  title           String
  h1              String?
  metaDescription String?
  summary         String?
  contentMdx      String
  sections        Json?
  internalLinks   Json?
  affiliateLinks  Json?
  evidenceIds     Json?
  jsonLd          Json?
  qualityScore    Int      @default(0)
  indexStatus     String   @default("pending")
  publishStatus   String   @default("draft")
  healthSensitivity String @default("none")
  complianceStatus String @default("unchecked")
  complianceJson   Json?
  canonicalUrl    String?
  hreflangMap     Json?
  archivedAt      DateTime?
  lastUpdated     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  affiliateClicks AffiliateClick[]
  affiliatePlacements AffiliatePlacement[]
  sourceTranslationGroups TranslationGroup[] @relation("TranslationGroupSourceArticle")
  translationVariants TranslationVariant[]
  publishingJobs PublishingJob[]
  distributionAssets DistributionAsset[]
  linkableAssets LinkableAsset[]

  @@unique([locale, slug, type])
  @@index([market, language, publishStatus])
  @@index([locale, type, indexStatus])
  @@index([healthSensitivity, complianceStatus])
}

model Merchant {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  domain          String
  merchantType    String
  allowedDomains  Json
  defaultRel      String   @default("sponsored nofollow")
  healthSensitive Boolean  @default(false)
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  programs        AffiliateProgram[]
  offers          Offer[]
  affiliateClicks AffiliateClick[]
}

model AffiliateProgram {
  id         String   @id @default(cuid())
  merchantId String
  merchant   Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  network    String
  trackingId String?
  termsNote  String?
  status     String   @default("active")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  offers     Offer[]
}

model Offer {
  id              String   @id @default(cuid())
  merchantId      String
  merchant        Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  programId       String?
  program         AffiliateProgram? @relation(fields: [programId], references: [id], onDelete: SetNull)
  productId       String?
  product         Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  topicId         String?
  topic           Topic? @relation(fields: [topicId], references: [id], onDelete: SetNull)
  title           String
  description     String?
  url             String
  affiliateUrl    String
  price           Decimal? @db.Decimal(10, 2)
  currency        String?
  locale          String?
  country         String?
  category        String
  evidenceLevel   String   @default("merchant_claim")
  healthSensitive Boolean  @default(false)
  lastCheckedAt   DateTime?
  status          String   @default("active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  affiliatePlacements AffiliatePlacement[]
  affiliateClicks     AffiliateClick[]

  @@index([merchantId, locale, category])
  @@index([productId])
  @@index([topicId])
}

model TrendSource {
  id         String   @id @default(cuid())
  name       String
  slug       String   @unique
  sourceType String
  market     String?
  language   String?
  locale     String?
  country    String?
  enabled    Boolean  @default(true)
  reliabilityTier String @default("manual_reviewed")
  collectionMode  String @default("manual_csv")
  configJson Json?
  lastCollectedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  signals    TrendSignal[]

  @@index([market, language, enabled])
}

model TrendSignal {
  id                String   @id @default(cuid())
  sourceId          String
  source            TrendSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  market            String?
  language          String?
  locale            String
  country           String?
  query             String
  rawKeyword        String?
  normalizedKeyword String?
  topicRaw          String
  categoryGuess     String?
  url               String?
  observedAt        DateTime?
  sourceRank        Int?
  sourceVolumeBucket String?
  relativeGrowth    Float?
  velocityScore     Float    @default(0)
  volumeScore       Float    @default(0)
  growthScore       Float    @default(0)
  competitionScore  Float    @default(0)
  commercialHintScore Float @default(0)
  commercialScore   Float    @default(0)
  freshnessScore    Float    @default(0)
  evidenceHintScore Float @default(0)
  evidenceFitScore  Float    @default(0)
  localeSpecificityScore Float @default(0)
  affiliateFitScore Float    @default(0)
  rawJson           Json?
  capturedAt        DateTime @default(now())

  topicSignals      TopicSignal[]

  @@index([market, language, capturedAt])
  @@index([locale, country, capturedAt])
  @@index([query])
}

model TrendCluster {
  id                  String   @id @default(cuid())
  market              String
  language            String
  canonicalTopic      String
  slug                String
  category            String?
  detectedAt          DateTime @default(now())
  status              String   @default("clustered")
  signalCount         Int      @default(0)
  countriesSeenJson   Json?
  relatedKeywordsJson Json?
  score               Float    @default(0)
  scoreBreakdownJson  Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([market, language, slug])
  @@index([market, language, status, score])
}

model TrendKeyword {
  id                String   @id @default(cuid())
  clusterId         String
  market            String
  language          String
  keyword           String
  searchIntentGuess String
  priorityScore     Float    @default(0)
  serpStatus        String   @default("pending")
  status            String   @default("serp_pending")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([clusterId])
  @@index([market, language, status, priorityScore])
}

model SerpSnapshot {
  id             String   @id @default(cuid())
  market         String
  language       String
  country        String
  keywordId      String
  keyword        String
  provider       String
  collectedAt    DateTime @default(now())
  status         String   @default("imported")
  rawJson        Json?
  topResultCount Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([keywordId, provider])
  @@index([market, language, collectedAt])
}

model SerpResult {
  id                    String   @id @default(cuid())
  snapshotId            String
  rank                  Int
  url                   String
  domain                String
  title                 String
  snippet               String?
  resultType            String
  dateHint              String?
  isForum               Boolean  @default(false)
  isVideo               Boolean  @default(false)
  isEcommerce           Boolean  @default(false)
  isAffiliateLikely     Boolean  @default(false)
  isPublisher           Boolean  @default(false)
  languageGuess         String?
  contentFetchedStatus  String   @default("pending")
  contentAnalysisStatus String   @default("pending")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([snapshotId, rank])
  @@index([domain])
}

model CompetitorContentAnalysis {
  id                     String   @id @default(cuid())
  serpResultId            String
  market                  String
  language                String
  keyword                 String
  pageTitle               String?
  h1                      String?
  headingsJson            Json?
  wordCountEstimate       Int?
  contentTypeGuess        String?
  intentServed            String?
  monetizationPattern     String?
  affiliatePattern        String?
  comparisonTablePresent  Boolean  @default(false)
  productLinksPresent     Boolean  @default(false)
  originalDataPresent     Boolean  @default(false)
  freshnessSignalsJson    Json?
  contentAnglesJson       Json?
  missingAnglesJson       Json?
  strengthsJson           Json?
  weaknessesJson          Json?
  extractionStatus        String   @default("summary_only")
  analyzedAt              DateTime @default(now())
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([serpResultId])
  @@index([market, language, keyword])
}

model SerpKeywordOpportunity {
  id                       String   @id @default(cuid())
  keywordId                String
  market                   String
  language                 String
  opportunityScore         Float    @default(0)
  dominantIntent           String
  dominantContentTypesJson Json?
  topPatternsJson          Json?
  contentGapJson           Json?
  recommendedAngle         String
  recommendedArticleType   String
  shouldWrite              Boolean  @default(false)
  reason                   String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@index([keywordId])
  @@index([market, language, shouldWrite, opportunityScore])
}

model ContentStrategy {
  id                      String   @id @default(cuid())
  keywordId               String
  clusterId               String
  market                  String
  language                String
  selectedArticleType     String
  recommendedAngle        String
  titleStrategy           String
  introStrategy           String?
  sectionPlanJson         Json?
  differentiationPlanJson Json?
  evidenceNeededJson      Json?
  competitorPatternsJson  Json?
  contentGapJson          Json?
  monetizationDeferred    Boolean  @default(true)
  status                  String   @default("brief_pending")
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([keywordId])
  @@index([market, language, status])
}

model TestArticle {
  id             String   @id @default(cuid())
  strategyId     String
  articleId      String?
  market         String
  language       String
  status         String   @default("test_pending")
  noindexReason  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([strategyId])
  @@index([market, language, status])
}

model MarketEditorialCalendar {
  id          String   @id @default(cuid())
  market      String
  language    String
  weekStart   DateTime
  status      String   @default("draft")
  summaryJson Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([market, language, weekStart])
}

model EditorialSlot {
  id         String   @id @default(cuid())
  calendarId String
  date       DateTime
  priority   Int
  clusterId  String?
  keywordId  String?
  strategyId String?
  articleId  String?
  status     String   @default("candidate")
  reason     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([calendarId, priority])
  @@index([keywordId])
}

model ArticlePerformanceSnapshot {
  id          String   @id @default(cuid())
  articleId   String
  market      String
  language    String
  dateStart   DateTime
  dateEnd     DateTime
  impressions Int      @default(0)
  clicks      Int      @default(0)
  ctr         Float    @default(0)
  avgPosition Float    @default(0)
  queriesJson Json?
  countriesJson Json?
  devicesJson Json?
  capturedAt  DateTime @default(now())

  @@index([articleId, capturedAt])
  @@index([market, language])
}

model ArticleNextAction {
  id          String   @id @default(cuid())
  articleId   String
  actionType  String
  reason      String
  priority    String
  payloadJson Json?
  status      String   @default("open")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([articleId, status])
  @@index([actionType, priority])
}

model ProductCandidate {
  id                 String   @id @default(cuid())
  articleId          String?
  market             String
  language           String
  sourceMerchant     String
  sourceMode         String
  title              String
  productUrl         String?
  candidateUrl       String?
  category           String?
  priceText          String?
  currency           String?
  imageUrl           String?
  reason             String?
  relevanceScore     Float    @default(0)
  riskScore          Float    @default(0)
  evidenceNeededJson Json?
  status             String   @default("analysis_pending")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([articleId])
  @@index([market, language, status])
}

model ProductCandidateAnalysis {
  id                    String   @id @default(cuid())
  articleId             String
  market                String
  language              String
  candidatesJson        Json?
  comparisonJson        Json?
  prosConsJson          Json?
  riskNotesJson         Json?
  recommendedUseJson    Json?
  monetizationReadiness String   @default("human_review_required")
  status                String   @default("do_not_link_yet")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([articleId])
  @@index([market, language, status])
}

model MonetizationReview {
  id                       String   @id @default(cuid())
  articleId                String
  market                   String
  language                 String
  productAnalysisId        String
  status                   String   @default("pending_human_review")
  reviewerNotes            String?
  approvedCandidateIdsJson Json?
  rejectedCandidateIdsJson Json?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@index([articleId])
  @@index([status])
}

model MonetizedPlacementDraft {
  id             String   @id @default(cuid())
  articleId      String
  candidateId    String
  merchant       String
  placementType  String
  anchorText     String
  disclosureText String
  rel            String   @default("sponsored nofollow")
  status         String   @default("draft")
  createdAt      DateTime @default(now())

  @@index([articleId, status])
  @@index([candidateId])
}

model Topic {
  id              String   @id @default(cuid())
  canonicalTopic  String
  slug            String   @unique
  cluster         String
  primaryLocale   String
  intent          String
  healthSensitive Boolean  @default(false)
  status          String   @default("candidate")
  score           Float    @default(0)
  scoreBreakdown  Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  topicSignals    TopicSignal[]
  contentBriefs   ContentBrief[]
  offers          Offer[]
  translationGroups TranslationGroup[]
  publishingJobs PublishingJob[]
}

model TopicSignal {
  id            String @id @default(cuid())
  topicId       String
  topic         Topic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  trendSignalId String
  trendSignal   TrendSignal @relation(fields: [trendSignalId], references: [id], onDelete: Cascade)
  weight        Float @default(1)

  @@index([topicId])
  @@index([trendSignalId])
  @@unique([topicId, trendSignalId])
}

model ContentBrief {
  id                String   @id @default(cuid())
  topicId           String
  topic             Topic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  locale            String
  articleType       String
  titleCandidate    String
  h1Candidate       String?
  searchIntent      String
  outlineJson       Json
  requiredEvidence  Json?
  merchantFitJson   Json?
  localizationNotes Json?
  healthSensitivity String   @default("none")
  status            String   @default("draft")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([topicId, locale])
}

model TranslationGroup {
  id               String   @id @default(cuid())
  canonicalTopicId String?
  canonicalTopic   Topic?   @relation(fields: [canonicalTopicId], references: [id], onDelete: SetNull)
  sourceArticleId  String?
  sourceArticle    Article? @relation("TranslationGroupSourceArticle", fields: [sourceArticleId], references: [id], onDelete: SetNull)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  variants         TranslationVariant[]

  @@index([canonicalTopicId])
  @@index([sourceArticleId])
}

model TranslationVariant {
  id                     String   @id @default(cuid())
  groupId                String
  group                  TranslationGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  articleId              String
  article                Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  locale                 String
  sourceLocale           String?
  localizationDepthScore Float    @default(0)
  status                 String   @default("draft")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([groupId, locale])
  @@index([articleId])
  @@unique([groupId, locale])
  @@unique([articleId])
}

model PublishingJob {
  id         String   @id @default(cuid())
  topicId    String?
  topic      Topic?   @relation(fields: [topicId], references: [id], onDelete: SetNull)
  articleId  String?
  article    Article? @relation(fields: [articleId], references: [id], onDelete: SetNull)
  locale     String
  jobType    String
  status     String   @default("queued")
  inputJson  Json?
  outputJson Json?
  error      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([status, jobType])
  @@index([articleId])
  @@index([topicId])
}

model AffiliatePlacement {
  id              String   @id @default(cuid())
  articleId       String
  article         Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  offerId         String
  offer           Offer    @relation(fields: [offerId], references: [id], onDelete: Cascade)
  placementType   String
  anchorText      String
  rel             String   @default("sponsored nofollow")
  disclosureShown Boolean  @default(false)
  status          String   @default("draft")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  affiliateClicks AffiliateClick[]

  @@index([articleId, status])
  @@index([offerId])
}

model AffiliateClick {
  id          String   @id @default(cuid())
  articleId   String?
  article     Article? @relation(fields: [articleId], references: [id], onDelete: SetNull)
  placementId String?
  placement   AffiliatePlacement? @relation(fields: [placementId], references: [id], onDelete: SetNull)
  offerId     String?
  offer       Offer? @relation(fields: [offerId], references: [id], onDelete: SetNull)
  merchantId  String?
  merchant    Merchant? @relation(fields: [merchantId], references: [id], onDelete: SetNull)
  productId   String?
  variantId   String?
  locale      String?
  targetUrl   String
  clickedAt   DateTime @default(now())
  referrer    String?
  utm         Json?

  @@index([productId, locale])
  @@index([placementId])
  @@index([offerId])
  @@index([merchantId])
}

model SearchConsoleMetric {
  id          String   @id @default(cuid())
  page        String
  query       String
  country     String?
  device      String?
  clicks      Int      @default(0)
  impressions Int      @default(0)
  ctr         Float    @default(0)
  position    Float    @default(0)
  startDate   DateTime?
  endDate     DateTime?
  importedAt  DateTime @default(now())

  @@index([page, query])
  @@index([country, device])
}

model PageRefreshSuggestion {
  id        String   @id @default(cuid())
  page      String
  query     String?
  reason    String
  actions   Json
  status    String   @default("open")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([page, status])
}

model DistributionAsset {
  id          String   @id @default(cuid())
  articleId   String
  article     Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  locale      String
  assetType   String
  platform    String
  title       String?
  body        String
  mediaUrls   Json?
  targetUrl   String?
  disclosure  String?
  status      String   @default("draft")
  scheduledAt DateTime?
  postedAt    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  results     DistributionResult[]

  @@index([articleId, status])
  @@index([platform, locale, status])
}

model DistributionRule {
  id                    String   @id @default(cuid())
  platform              String
  locale                String
  maxPostsPerDay         Int      @default(2)
  requiresHumanApproval Boolean  @default(true)
  allowDirectLink        Boolean  @default(true)
  requireDisclosure      Boolean  @default(true)
  enabled               Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([platform, locale])
  @@index([enabled, platform, locale])
}

model DistributionResult {
  id             String   @id @default(cuid())
  assetId        String
  asset          DistributionAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  platform       String
  externalPostId String?
  externalUrl    String?
  impressions    Int?
  clicks         Int?
  likes          Int?
  comments       Int?
  shares         Int?
  error          String?
  capturedAt     DateTime @default(now())

  @@index([assetId])
  @@index([platform, capturedAt])
}

model LinkableAsset {
  id                String   @id @default(cuid())
  articleId          String?
  article            Article? @relation(fields: [articleId], references: [id], onDelete: SetNull)
  url                String   @unique
  locale             String
  topic              String
  assetType          String
  title              String
  summary            String
  originalDataScore  Float    @default(0)
  linkableScore      Float    @default(0)
  status             String   @default("active")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  prospects          LinkProspect[] @relation("SuggestedLinkableAsset")
  campaigns          OutreachCampaign[]

  @@index([locale, assetType, status])
  @@index([linkableScore])
}

model LinkProspect {
  id               String   @id @default(cuid())
  domain           String
  pageUrl          String
  pageTitle        String?
  locale           String?
  topic            String?
  opportunityType  String
  suggestedAssetId String?
  suggestedAsset   LinkableAsset? @relation("SuggestedLinkableAsset", fields: [suggestedAssetId], references: [id], onDelete: SetNull)
  suggestedAngle   String?
  topicalRelevance Float    @default(0)
  pageQuality      Float    @default(0)
  spamRisk         Float    @default(0)
  prospectScore    Float    @default(0)
  contactEmail     String?
  contactFormUrl   String?
  status           String   @default("new")
  discoveredAt     DateTime @default(now())
  lastContactedAt  DateTime?
  notes            String?

  outreachMessages OutreachMessage[]

  @@index([domain])
  @@index([status, prospectScore])
  @@index([suggestedAssetId])
}

model OutreachCampaign {
  id             String   @id @default(cuid())
  name           String
  assetId        String
  asset          LinkableAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  locale         String
  status         String   @default("draft")
  dailySendLimit Int      @default(10)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  messages       OutreachMessage[]

  @@index([assetId, status])
  @@index([locale, status])
}

model OutreachMessage {
  id              String   @id @default(cuid())
  campaignId      String
  campaign        OutreachCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  prospectId      String
  prospect        LinkProspect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  subject         String
  body            String
  status          String   @default("draft")
  approvedByHuman Boolean  @default(false)
  sentAt          DateTime?
  repliedAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([campaignId, status])
  @@index([prospectId])
}

model SuppressionEntry {
  id        String   @id @default(cuid())
  email     String?
  domain    String?
  reason    String
  createdAt DateTime @default(now())

  @@index([email])
  @@index([domain])
}

model AuditLog {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  action     String
  actor      String?
  summary    String?
  beforeJson Json?
  afterJson  Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}
