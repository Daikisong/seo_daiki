{
  "name": "@global-import-lab/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/client.ts",
    "./affiliate-clicks": "./src/affiliateClicks.ts",
    "./admin-mutations": "./src/adminMutations.ts",
    "./content": "./src/contentRepository.ts",
    "./lab-evidence": "./src/labEvidence.ts",
    "./search-console": "./src/searchConsole.ts",
    "./worker-import": "./src/importWorkerOutputs.ts"
  },
  "scripts": {
